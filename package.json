{
  "name": "databreef",
  "version": "0.1.0",
  "private": true,
  "description": "DataBreef monorepo — Your schema, surfaced.",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "clean": "pnpm --recursive exec rm -rf .next dist .astro node_modules/.cache"
  },
  "devDependencies": {
    "@types/argon2": "^0.15.4",
    "@types/zxcvbn": "^4.4.5",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
