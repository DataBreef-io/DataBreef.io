---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated = 'April 2026' } = Astro.props;
---

<Base title={`${title} — DataBreef`} description={description}>
  <div class="legal-page">
    <div class="legal-container">
      <header class="legal-header fade-up">
        <p class="eyebrow">Legal</p>
        <h1 class="legal-title">{title}</h1>
        <p class="legal-updated">Last updated: {lastUpdated}</p>
      </header>
      <div class="legal-body">
        <slot />
      </div>
    </div>
  </div>
</Base>

<style>
  .legal-page {
    padding-top: 72px;
    background: var(--color-abyss);
    min-height: 100vh;
  }

  .legal-container {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-24);
  }

  .legal-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--border-subtle);
  }

  .legal-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--space-2) 0 var(--space-3);
    line-height: var(--leading-tight);
  }

  .legal-updated {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .legal-body :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--space-10) 0 var(--space-4);
  }

  .legal-body :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-seafoam);
    margin: var(--space-6) 0 var(--space-2);
  }

  .legal-body :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .legal-body :global(ul) {
    margin: var(--space-3) 0 var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .legal-body :global(li) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .legal-body :global(a) {
    color: var(--color-foam);
    text-decoration: underline;
    text-decoration-color: hsl(172 65% 50% / 0.4);
    transition: text-decoration-color var(--duration-fast) var(--ease-out-expo);
  }

  .legal-body :global(a:hover) {
    text-decoration-color: var(--color-foam);
  }

  .legal-body :global(.legal-contact) {
    margin-top: var(--space-12);
    padding: var(--space-6);
    background: var(--color-reef);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
  }

  .legal-body :global(.legal-contact h2) {
    margin-top: 0;
  }

  .legal-body :global(.legal-contact p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .legal-title { font-size: var(--text-3xl); }
  }
</style>
