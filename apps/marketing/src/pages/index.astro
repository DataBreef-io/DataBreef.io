---
/**
 * DataBreef Marketing Landing Page
 * Assembles all sections in order. Each component is self-contained.
 *
 * Section order:
 *   1. Hero              — full-viewport, ambient particles
 *   2. TrustBar          — 4 trust pillars below the fold
 *   3. ReefComparison    — THE centerpiece draggable slider
 *   4. HowItWorks        — 3-step process cards
 *   5. SecuritySection   — 4 technical trust pillars in 2×2 grid
 *   6. FinalCTA          — closing conversion with coral horizon
 *   (Footer and Navbar are injected by Base.astro)
 */
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ReefComparison from '../components/ReefComparison.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SecuritySection from '../components/SecuritySection.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<Base
  title="DataBreef — Your schema, surfaced."
  description="DataBreef reads every table, relationship, and pattern in your PostgreSQL schema — and surfaces what matters. Read-only. Secure. Beautifully clear."
>
  <Hero />
  <TrustBar />
  <ReefComparison />
  <HowItWorks />
  <SecuritySection />
  <FinalCTA />
</Base>
