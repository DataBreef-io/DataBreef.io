    <h2>Report a Security Issue</h2>
    <p>Security reports and questions:</p>
    <p><strong>DataBreef Security</strong> — <a href="mailto:security@databreef.io">security@databreef.io</a></p>
    <p>For general compliance inquiries: <a href="mailto:legal@databreef.io">legal@databreef.io</a></p>
  </div>
</LegalLayout>
