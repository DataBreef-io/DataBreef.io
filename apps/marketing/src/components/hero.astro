---
/**
 * Hero — full viewport height, centered, with ambient particles + wave scroll indicator.
 * All animations are CSS-only. Respects prefers-reduced-motion.
 */
---

<section class="hero" aria-labelledby="hero-headline">

  <!-- Ambient background layers -->
  <div class="hero-bg" aria-hidden="true">
    <div class="bg-shaft bg-shaft-1"></div>
    <div class="bg-shaft bg-shaft-2"></div>
    <div class="bg-shaft bg-shaft-3"></div>
  </div>

  <!-- Floating particles -->
  <div class="particles" aria-hidden="true">
    <span class="particle" style="--x:8%;  --delay:0s;    --size:3px; --dur:9s"></span>
    <span class="particle" style="--x:18%; --delay:2.3s;  --size:2px; --dur:11s"></span>
    <span class="particle" style="--x:29%; --delay:4.8s;  --size:2.5px;--dur:8s"></span>
    <span class="particle" style="--x:43%; --delay:1.5s;  --size:2px; --dur:13s"></span>
    <span class="particle" style="--x:56%; --delay:3.2s;  --size:3px; --dur:10s"></span>
    <span class="particle" style="--x:67%; --delay:6.1s;  --size:2px; --dur:12s"></span>
    <span class="particle" style="--x:78%; --delay:0.8s;  --size:2.5px;--dur:9s"></span>
    <span class="particle" style="--x:89%; --delay:5.4s;  --size:2px; --dur:14s"></span>
    <span class="particle" style="--x:94%; --delay:2.8s;  --size:3px; --dur:8s"></span>
    <span class="particle" style="--x:35%; --delay:7.2s;  --size:1.5px;--dur:11s"></span>
    <span class="particle" style="--x:62%; --delay:4.1s;  --size:2px; --dur:10s"></span>
    <span class="particle" style="--x:12%; --delay:9s;    --size:2.5px;--dur:12s"></span>
  </div>


  <!-- Main content -->
  <div class="container hero-content">

    <div class="hero-layout">
      <div class="hero-inner">
        <p class="eyebrow fade-up fade-up-1" aria-label="Tagline">
          Read-only · Open source · Self-hostable
        </p>

        <h1 class="hero-headline fade-up fade-up-2" id="hero-headline">
          The intelligence layer for your
          <em class="headline-accent">PostgreSQL schema.</em>
        </h1>

        <p class="hero-subtext fade-up fade-up-3">
          DataBreef reads every table, relationship, and pattern in your database
          — and surfaces what matters. <strong>Read-only. Secure. Beautifully clear.</strong>
        </p>

        <div class="hero-ctas fade-up fade-up-4">
          <a href="https://app.databreef.io/sign-up" class="btn btn-primary btn-primary-lg" id="hero-cta-primary">
            Start surfacing → free
          </a>
          <a href="#reef-comparison" class="btn btn-ghost btn-primary-lg" id="hero-cta-secondary">
            See it in action ↓
          </a>
        </div>

        <!-- Trust nudge -->
        <p class="hero-trust fade-up fade-up-4">
          No credit card. No schema changes. Ever.
        </p>
      </div>

      <!-- Diver visual (right side) -->
      <div class="hero-diver-wrapper">
        <video
          class="hero-diver"
          autoplay
          muted
          loop
          playsinline
          disablePictureInPicture
        >
          <source src="/diver-hero.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-hidden="true">
    <svg width="20" height="32" viewBox="0 0 20 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="1" y="1" width="18" height="30" rx="9" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
      <circle class="scroll-dot" cx="10" cy="10" r="3" fill="currentColor"/>
    </svg>
  </div>

  <!-- Wave bottom transition -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="var(--color-deep)"/>
    </svg>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-abyss);
    overflow: hidden;
    padding-top: 72px; /* navbar height */
  }

  /* ── Ambient background shafts ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bg-shaft {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }

  .bg-shaft-1 {
    width: 60%;
    height: 80%;
    bottom: -20%;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, hsl(172 65% 28% / 0.4), transparent 70%);
  }

  .bg-shaft-2 {
    width: 40%;
    height: 50%;
    top: 10%;
    left: 5%;
    background: radial-gradient(ellipse, hsl(200 60% 22% / 0.3), transparent 70%);
    animation: shaftDrift 14s ease-in-out infinite alternate;
  }

  .bg-shaft-3 {
    width: 35%;
    height: 45%;
    top: 15%;
    right: 8%;
    background: radial-gradient(ellipse, hsl(185 60% 20% / 0.25), transparent 70%);
    animation: shaftDrift 11s ease-in-out infinite alternate-reverse;
  }

  @keyframes shaftDrift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(2%, 4%) scale(1.08); }
  }

  /* ── Particles ── */
  .particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    left: var(--x);
    bottom: 15%;
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: var(--color-foam);
    opacity: 0;
    animation: floatUp var(--dur, 10s) var(--delay, 0s) ease-in-out infinite;
  }

  @keyframes floatUp {
    0%   { transform: translateY(0); opacity: 0.5; }
    40%  { opacity: 0.7; }
    100% { transform: translateY(-65vh) scale(0.2); opacity: 0; }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: var(--space-24);
  }

  .hero-layout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-12);
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-inner {
    flex: 1;
    text-align: left;
    max-width: 500px;
  }

  .hero-diver-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 500px;
    position: relative;
  }

  .hero-diver-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      transparent 0%,
      transparent 50%,
      rgba(11, 27, 40, 0.3) 85%,
      rgb(11, 27, 40) 100%
    );
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 400;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
    margin-top: var(--space-4);
  }

  .headline-accent {
    color: var(--color-foam);
    font-style: italic;
    display: block;
  }

  .hero-subtext {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 580px;
    margin: 0 auto var(--space-8);
  }

  .hero-subtext strong {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-5);
  }

  .hero-trust {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: var(--space-10);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-surface);
    z-index: 2;
    animation: hintBounce 3s ease-in-out infinite;
  }

  .scroll-dot {
    animation: dotScroll 3s ease-in-out infinite;
  }

  @keyframes dotScroll {
    0%, 100% { cy: 10; opacity: 1; }
    60%       { cy: 22; opacity: 0.2; }
  }

  @keyframes hintBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Wave ── */
  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .hero-wave svg {
    width: 100%;
    height: 60px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-layout {
      flex-direction: column;
      gap: var(--space-8);
    }
    .hero-inner {
      text-align: center;
      max-width: 100%;
    }
    .hero-diver-wrapper {
      height: 350px;
    }
  }

  @media (max-width: 768px) {
    .hero-layout {
      flex-direction: column;
    }
    .hero-inner {
      text-align: center;
    }
    .hero-headline { font-size: clamp(2.2rem, 8vw, 3rem); }
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { text-align: center; }
    .hero-diver-wrapper {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .particle, .bg-shaft-2, .bg-shaft-3, .scroll-hint, .scroll-dot { animation: none; }
    .particle { opacity: 0.4; }
  }

  /* ── Diver video ── */
  .hero-diver {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.3));
  }
</style>
