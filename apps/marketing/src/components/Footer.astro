---
/**
 * Footer — minimal, ocean-themed. Links + legal.
 */
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">

    <!-- Brand + tagline -->
    <div class="footer-brand">
      <a href="/" class="brand-link" aria-label="DataBreef home">
        <span class="brand-data">Data</span><span class="brand-breef">Breef</span>
      </a>
      <p class="brand-tagline">Your schema, surfaced.</p>
    </div>

    <!-- Link columns -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-col">
        <p class="col-heading">Product</p>
        <a href="#features">Features</a>
        <a href="#security">Security</a>
        <a href="/pricing">Pricing</a>
        <a href="https://app.databreef.io/sign-up">Start free</a>
      </div>
      <div class="footer-col">
        <p class="col-heading">Resources</p>
        <a href="https://docs.databreef.io">Documentation</a>
        <a href="https://github.com/databreef/databreef">GitHub</a>
        <a href="/changelog">Changelog</a>
        <a href="/blog">Blog</a>
      </div>
      <div class="footer-col">
        <p class="col-heading">Deploy</p>
        <a href="https://vercel.com">Vercel (cloud)</a>
        <a href="https://github.com/databreef/databreef/pkgs/container/databreef">Docker image</a>
        <a href="https://docs.databreef.io/self-hosting">Self-hosting guide</a>
      </div>
    </nav>

    <!-- Self-hostable badge -->
    <div class="footer-oss">
      <a href="https://github.com/databreef/databreef" class="oss-badge" aria-label="View DataBreef on GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        Open source on GitHub
      </a>
    </div>

  </div>

  <!-- Legal -->
  <div class="footer-legal">
    <p>© 2026 DataBreef. MIT License. Read-only. Always.</p>
    <div class="legal-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/security">Security</a>
      <a href="/cookies">Cookies</a>
      <a href="/dpa">DPA</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-deep);
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-12);
    display: grid;
    grid-template-columns: 260px 1fr auto;
    gap: var(--space-12);
    align-items: start;
  }

  /* Brand */
  .brand-link {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    text-decoration: none;
    letter-spacing: var(--tracking-tight);
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .brand-data { color: var(--text-primary); }
  .brand-breef { color: var(--color-foam); }
  .brand-tagline {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  /* Nav columns */
  .footer-nav {
    display: flex;
    gap: var(--space-12);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .col-heading {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .footer-col a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .footer-col a:hover {
    color: var(--color-foam);
  }

  /* OSS Badge */
  .footer-oss {
    align-self: start;
  }

  .oss-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    background: var(--color-reef);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo),
      background var(--duration-fast) var(--ease-out-expo);
  }

  .oss-badge:hover {
    color: var(--color-foam);
    border-color: hsl(172 65% 50% / 0.4);
    background: hsl(172 65% 50% / 0.08);
  }

  /* Legal */
  .footer-legal {
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-6);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer-legal p {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .legal-links {
    display: flex;
    gap: var(--space-4);
  }

  .legal-links a {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .legal-links a:hover {
    color: var(--color-foam);
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .footer-nav { flex-wrap: wrap; gap: var(--space-8); }
  }

  @media (max-width: 500px) {
    .footer-legal { flex-direction: column; align-items: flex-start; }
  }
</style>
