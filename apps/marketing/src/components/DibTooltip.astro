---
/**
 * DibTooltip — A lightweight, CSS-only tooltip for the term "Dib" or "Dibs".
 * Highlights the custom term and provides a definition on hover.
 */
interface Props {
  noUnderline?: boolean;
}

const { noUnderline = false } = Astro.props;
---

<span class={`dib-tooltip ${noUnderline ? 'no-underline' : ''}`} tabIndex="0">
  <slot />
  <span class="tooltip-box" role="tooltip">
    <strong class="tooltip-title">Data Intelligence Brief</strong>
    <span class="tooltip-body">A comprehensive, AI-generated schema report of your data reef.</span>
  </span>
</span>

<style>
  .dib-tooltip {
    position: relative;
    display: inline-block;
    cursor: help;
    border-bottom: 1px dotted var(--color-foam);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .dib-tooltip.no-underline {
    border-bottom: none;
  }

  /* The Popover Box */
  .tooltip-box {
    visibility: hidden;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--color-deep);
    border: 1px solid var(--border-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    width: 260px;
    box-shadow: var(--shadow-xl), 0 0 30px hsl(172 65% 50% / 0.1);
    z-index: 200;
    opacity: 0;
    transition: 
      opacity var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo),
      visibility var(--duration-normal) var(--ease-out-expo);
    pointer-events: none;
    text-align: left;
    white-space: normal;
  }

  /* Triangle Arrow */
  .tooltip-box::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px;
    border-style: solid;
    border-color: var(--border-accent) transparent transparent transparent;
  }

  .tooltip-title {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-foam);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .tooltip-body {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  /* Interaction */
  .dib-tooltip:hover .tooltip-box,
  .dib-tooltip:focus-within .tooltip-box {
    visibility: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .dib-tooltip:hover {
    color: var(--color-foam);
  }

  @media (max-width: 600px) {
    .tooltip-box {
      width: 200px;
      left: 0;
      transform: translateX(0);
    }
    .tooltip-box::after {
      left: 20px;
    }
    .dib-tooltip:hover .tooltip-box {
      transform: translateX(0);
    }
  }
</style>
